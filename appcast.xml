        <item>
            <title>Version 0.1.1</title>
            <pubDate>Sun, 19 Apr 2026 19:41:40 +0000</pubDate>
            <sparkle:version>2</sparkle:version>
            <sparkle:shortVersionString>0.1.1</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h2>What's New in 0.1.1</h2>
                <ul>
                    <li>Auto-tile all windows on current display (Ctrl+Alt+T)</li>
                    <li>Undo last snap (Ctrl+Alt+Z)</li>
                    <li>Snap-to-thirds for ultrawides (Ctrl+Alt+1/2/3)</li>
                    <li>Grow windows by grid cell (Ctrl+Alt+Shift+Arrow)</li>
                    <li>App pinning with one-key reset</li>
                    <li>Custom app icon</li>
                    <li>Settings UI improvements</li>
                </ul>
            ]]></description>
